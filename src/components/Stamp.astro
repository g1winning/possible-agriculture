---
export interface Props {
  text?: string;
  variant?: 'light' | 'dark';
}

const { text = 'Produced in Central Victoria', variant = 'light' } = Astro.props;
---

<div
  class={`inline-flex items-center gap-3 px-4 py-2 rounded-pill border ${
    variant === 'dark'
      ? 'border-white/20 text-paper bg-white/5'
      : 'border-rule text-ink bg-paper'
  }`}
>
  <svg
    width="16"
    height="16"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    aria-hidden="true"
  >
    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z" />
    <circle cx="12" cy="10" r="3" />
  </svg>
  <span class="eyebrow !text-current">{text}</span>
</div>
