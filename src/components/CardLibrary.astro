---
export interface Props {
  title: string;
  originalTitle?: string;
  authors: string;
  year: number;
  journal?: string;
  doi?: string;
  pdfFile?: string;
  whyItMatters: string;
  keyFinding: string;
  topics: string[];
  audience: string[];
  rating: 'foundational' | 'strong-evidence' | 'supporting' | 'context';
  citation: string;
  sourceUrl?: string;
  pubmedId?: string;
}

const props = Astro.props;

const ratingLabel: Record<string, string> = {
  foundational: 'Foundational',
  'strong-evidence': 'Strong evidence',
  supporting: 'Supporting',
  context: 'Context',
};

const ratingColor: Record<string, string> = {
  foundational: 'bg-bush-gold text-ink',
  'strong-evidence': 'bg-eucalypt text-paper',
  supporting: 'bg-bg-tint text-ink',
  context: 'bg-paper text-text-muted border border-rule',
};

const topicLabel: Record<string, string> = {
  'biochar-soil': 'Soil',
  'biochar-livestock': 'Livestock',
  'biochar-turf': 'Turf',
  'biochar-councils': 'Councils',
  'biochar-water': 'Water',
  'biochar-compost': 'Compost',
  'biochar-pfas': 'PFAS',
  'biochar-carbon': 'Carbon',
  'biochar-process': 'Process',
  silvaculture: 'Silvaculture',
  'farming-practice': 'Farming practice',
};

const audienceLabel: Record<string, string> = {
  farmers: 'Farmers',
  councils: 'Councils',
  turf: 'Turf',
  researchers: 'Researchers',
  general: 'General',
};

const pdfPath = props.pdfFile ? `/pdfs/library/${props.pdfFile}` : null;
const tagsData = [...props.topics, ...props.audience].join(' ').toLowerCase();
---

<article
  class="card-lift rounded-xl bg-paper border border-rule p-6 md:p-8 flex flex-col h-full library-card"
  data-tags={tagsData}
  data-rating={props.rating}
  data-title={props.title.toLowerCase()}
>
  <div class="flex items-center justify-between gap-4 mb-4">
    <span class={`inline-flex items-center px-2.5 py-1 rounded-pill text-caption font-display font-semibold ${ratingColor[props.rating]}`}>
      {ratingLabel[props.rating]}
    </span>
    <span class="text-caption text-text-muted font-mono">{props.year}</span>
  </div>

  <h3 class="font-display font-bold text-h3 leading-tight text-ink">
    {props.title}
  </h3>

  <p class="mt-3 text-body-sm italic text-eucalypt">
    Why this matters for your operation
  </p>
  <p class="mt-1 text-body text-text leading-relaxed">{props.whyItMatters}</p>

  <p class="mt-5 text-body-sm font-semibold text-ink">Key finding</p>
  <p class="mt-1 text-body-sm text-text-muted leading-relaxed">{props.keyFinding}</p>

  <div class="mt-6 flex flex-wrap gap-2">
    {props.topics.map((t) => (
      <span class="tag">{topicLabel[t] ?? t}</span>
    ))}
  </div>

  <div class="mt-6 pt-6 border-t border-rule text-caption text-text-muted">
    <p class="leading-relaxed">{props.citation}</p>
  </div>

  <div class="mt-6 flex flex-wrap gap-3">
    {pdfPath && (
      <a
        href={pdfPath}
        target="_blank"
        rel="noopener"
        class="btn btn-secondary !min-h-[40px] !py-2 !px-4 text-body-sm"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        Download PDF
      </a>
    )}
    {props.sourceUrl && (
      <a
        href={props.sourceUrl}
        target="_blank"
        rel="noopener"
        class={`btn ${!pdfPath ? 'btn-secondary' : 'btn-ghost'} !min-h-[40px] !py-2 !px-4 text-body-sm`}
      >
        {!pdfPath ? 'View at source' : 'View source'}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="7" y1="17" x2="17" y2="7" />
          <polyline points="7 7 17 7 17 17" />
        </svg>
      </a>
    )}
  </div>
</article>
