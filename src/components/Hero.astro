---
export interface Props {
  eyebrow?: string;
  heading: string;
  /** Sub-headline / lead paragraph. */
  lead?: string;
  primaryCta?: { label: string; href: string };
  secondaryCta?: { label: string; href: string };
  /** Hero image — should be in /public/images/hero/ */
  image?: string;
  imageAlt?: string;
  /** Layout variant. */
  layout?: 'split' | 'overlay' | 'minimal';
  /** Trust-strip items shown below CTAs. */
  trust?: string[];
  /** Whether to apply a warm vignette overlay (used for overlay variant). */
  vignette?: boolean;
}

const {
  eyebrow,
  heading,
  lead,
  primaryCta,
  secondaryCta,
  image,
  imageAlt = '',
  layout = 'split',
  trust = [],
  vignette = true,
} = Astro.props;
---

{
  layout === 'overlay' ? (
    <section class="relative bg-bark on-dark min-h-[80vh] flex items-end overflow-hidden">
      {image && (
        <div class={`absolute inset-0 ${vignette ? 'img-vignette' : ''}`}>
          <img
            src={image}
            alt={imageAlt}
            class="w-full h-full object-cover"
            loading="eager"
            fetchpriority="high"
            width="2400"
            height="1200"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-bark/95 via-bark/40 to-bark/10" aria-hidden="true" />
        </div>
      )}
      <div class="container-wide relative z-10 pb-16 md:pb-24 pt-32 md:pt-48">
        <div class="max-w-3xl">
          {eyebrow && <p class="eyebrow eyebrow-on-dark mb-4">{eyebrow}</p>}
          <h1 class="font-display font-extrabold text-h1 md:text-h1-lg leading-[1.05] tracking-tight text-balance">
            {heading}
          </h1>
          {lead && (
            <p class="mt-6 text-body-lg md:text-lg text-sky max-w-prose">{lead}</p>
          )}
          {(primaryCta || secondaryCta) && (
            <div class="mt-8 flex flex-wrap gap-4">
              {primaryCta && (
                <a href={primaryCta.href} class="btn btn-primary !min-h-[52px] !text-body">
                  {primaryCta.label}
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="5" y1="12" x2="19" y2="12" />
                    <polyline points="12 5 19 12 12 19" />
                  </svg>
                </a>
              )}
              {secondaryCta && (
                <a href={secondaryCta.href} class="btn btn-secondary btn-on-dark !min-h-[52px] !text-body">
                  {secondaryCta.label}
                </a>
              )}
            </div>
          )}
          {trust.length > 0 && (
            <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-caption text-sky">
              {trust.map((t) => (
                <li class="flex items-center gap-2">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#D9A65A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <polyline points="20 6 9 17 4 12" />
                  </svg>
                  <span>{t}</span>
                </li>
              ))}
            </ul>
          )}
        </div>
      </div>
    </section>
  ) : layout === 'split' ? (
    <section class="bg-paper">
      <div class="container-wide py-12 md:py-20 lg:py-28">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 items-center">
          <div class="lg:col-span-7">
            {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
            <h1 class="font-display font-extrabold text-h1 md:text-h1-lg leading-[1.05] tracking-tight text-balance">
              {heading}
            </h1>
            {lead && (
              <p class="mt-6 text-body-lg text-text-muted max-w-prose">{lead}</p>
            )}
            {(primaryCta || secondaryCta) && (
              <div class="mt-8 flex flex-wrap gap-4">
                {primaryCta && (
                  <a href={primaryCta.href} class="btn btn-primary !min-h-[52px] !text-body">
                    {primaryCta.label}
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <line x1="5" y1="12" x2="19" y2="12" />
                      <polyline points="12 5 19 12 12 19" />
                    </svg>
                  </a>
                )}
                {secondaryCta && (
                  <a href={secondaryCta.href} class="btn btn-secondary !min-h-[52px] !text-body">
                    {secondaryCta.label}
                  </a>
                )}
              </div>
            )}
            {trust.length > 0 && (
              <ul class="mt-10 flex flex-wrap gap-x-6 gap-y-2 text-caption text-text-muted">
                {trust.map((t) => (
                  <li class="flex items-center gap-2">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#A6772F" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <polyline points="20 6 9 17 4 12" />
                    </svg>
                    <span>{t}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
          <div class="lg:col-span-5">
            {image && (
              <div class={`relative rounded-2xl overflow-hidden shadow-lg ${vignette ? 'img-vignette' : ''}`}>
                <img
                  src={image}
                  alt={imageAlt}
                  class="w-full h-full object-cover aspect-[4/5] lg:aspect-[3/4]"
                  loading="eager"
                  fetchpriority="high"
                  width="1200"
                  height="1500"
                />
              </div>
            )}
          </div>
        </div>
      </div>
    </section>
  ) : (
    <section class="bg-paper">
      <div class="container-narrow text-center py-16 md:py-28">
        {eyebrow && <p class="eyebrow mb-4">{eyebrow}</p>}
        <h1 class="font-display font-extrabold text-h1 md:text-h1-lg leading-[1.05] tracking-tight text-balance">
          {heading}
        </h1>
        {lead && (
          <p class="mt-6 text-body-lg text-text-muted max-w-prose mx-auto">{lead}</p>
        )}
        {(primaryCta || secondaryCta) && (
          <div class="mt-8 flex flex-wrap gap-4 justify-center">
            {primaryCta && (
              <a href={primaryCta.href} class="btn btn-primary !min-h-[52px] !text-body">
                {primaryCta.label}
              </a>
            )}
            {secondaryCta && (
              <a href={secondaryCta.href} class="btn btn-secondary !min-h-[52px] !text-body">
                {secondaryCta.label}
              </a>
            )}
          </div>
        )}
      </div>
    </section>
  )
}
