---
import { site, nav } from '@lib/site';

const year = new Date().getFullYear();
---

<footer class="bg-bark on-dark" role="contentinfo">
  <div class="container-default py-16 md:py-24">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-10 md:gap-12">
      <!-- Brand block -->
      <div class="md:col-span-4">
        <div class="font-display font-extrabold text-2xl leading-tight">
          Possible Agriculture
        </div>
        <p class="mt-6 text-body text-sky max-w-prose">
          Biology-first farming, made practical for Australian conditions. We make biochar on your land, supply biochar by the m³, and consult on biological farming, forest management, carbon, and water.
        </p>
      </div>

      <!-- Biochar -->
      <div class="md:col-span-3">
        <h3 class="font-display font-bold text-body text-paper">Biochar</h3>
        <ul class="mt-4 flex flex-col gap-2">
          {
            nav.biocharSub.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-body-sm text-sky hover:text-paper no-underline transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Services -->
      <div class="md:col-span-3">
        <h3 class="font-display font-bold text-body text-paper">Services</h3>
        <ul class="mt-4 flex flex-col gap-2">
          {
            nav.servicesSub.map((item) => (
              <li>
                <a
                  href={item.href}
                  class="text-body-sm text-sky hover:text-paper no-underline transition-colors"
                >
                  {item.label}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <!-- Contact -->
      <div class="md:col-span-2">
        <h3 class="font-display font-bold text-body text-paper">Talk to us</h3>
        <ul class="mt-4 flex flex-col gap-3">
          <li>
            <a
              href={`tel:${site.founder.phoneTel}`}
              class="text-body-sm text-paper no-underline hover:text-bush-gold transition-colors flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
              </svg>
              {site.founder.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${site.founder.email}`}
              class="text-body-sm text-paper no-underline hover:text-bush-gold transition-colors flex items-start gap-2 break-all"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 mt-1">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                <polyline points="22,6 12,13 2,6" />
              </svg>
              <span class="break-all">{site.founder.email}</span>
            </a>
          </li>
          <li>
            <a
              href={site.social.youtube}
              target="_blank"
              rel="noopener"
              class="text-body-sm text-paper no-underline hover:text-bush-gold transition-colors flex items-center gap-2"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z" />
                <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" />
              </svg>
              YouTube
            </a>
          </li>
        </ul>
      </div>
    </div>

    <hr class="my-12 border-0 h-px bg-white/10" />

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6">
      <div class="flex flex-col md:flex-row md:items-center gap-2 md:gap-6 text-caption text-sky">
        <span>© {year} {site.legalName}.</span>
        <span class="hidden md:inline" aria-hidden="true">·</span>
        <span>{site.location.serviceArea}</span>
        {site.abn && (<><span class="hidden md:inline" aria-hidden="true">·</span><span>ABN {site.abn}</span></>)}
      </div>
      <div class="flex items-center gap-4 text-caption text-sky">
        <a href="/about" class="no-underline hover:text-paper transition-colors">About</a>
        <a href="/contact" class="no-underline hover:text-paper transition-colors">Contact</a>
      </div>
    </div>
  </div>
</footer>
