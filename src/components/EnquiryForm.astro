---
import { site } from '@lib/site';

export interface Props {
  /** Optional subject pre-fill, e.g. "Biochar quote — golf course". */
  subject?: string;
  /** Where to redirect after successful submission. */
  next?: string;
  /** Optional heading rendered above the form. */
  heading?: string;
  /** Optional intro paragraph. */
  intro?: string;
}

const {
  subject = 'Possible Agriculture enquiry',
  next = '/contact/thanks',
  heading,
  intro,
} = Astro.props;

// FormSubmit endpoint. First submission to a new address triggers an
// activation email Luca must click — until that, submissions go nowhere.
const action = site.formEndpoint;
---

<div class="bg-bg-tint border border-rule rounded-xl p-6 md:p-10">
  {heading && (
    <h2 class="font-display font-bold text-h2 leading-tight mb-3 text-balance">
      {heading}
    </h2>
  )}
  {intro && <p class="mb-8 text-body text-text-muted max-w-prose">{intro}</p>}

  <form action={action} method="POST" class="flex flex-col gap-5" novalidate>
    <!-- FormSubmit config -->
    <input type="hidden" name="_subject" value={subject} />
    <input type="hidden" name="_template" value="table" />
    <input type="hidden" name="_captcha" value="true" />
    <input type="hidden" name="_next" value={`${site.url}${next}`} />
    <!-- Honeypot — anti-spam -->
    <input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="name" class="field-label field-required">Your name</label>
        <input
          id="name"
          name="name"
          type="text"
          required
          autocomplete="name"
          class="field"
        />
      </div>
      <div>
        <label for="email" class="field-label field-required">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          autocomplete="email"
          inputmode="email"
          class="field"
        />
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      <div>
        <label for="phone" class="field-label">Phone (optional)</label>
        <input
          id="phone"
          name="phone"
          type="tel"
          autocomplete="tel"
          inputmode="tel"
          class="field"
        />
      </div>
      <div>
        <label for="org" class="field-label">Property / organisation</label>
        <input
          id="org"
          name="organisation"
          type="text"
          autocomplete="organization"
          class="field"
        />
      </div>
    </div>

    <div>
      <label for="enquiry-type" class="field-label">What's this about?</label>
      <select id="enquiry-type" name="enquiry_type" class="field">
        <option value="biochar-quote">Biochar — pricing & delivery</option>
        <option value="biochar-trial">Biochar — pilot trial on my property</option>
        <option value="consulting">Biological farming consult</option>
        <option value="forest-management">Forest management</option>
        <option value="carbon-farming">Carbon farming / ACCUs</option>
        <option value="water-treatment">Water treatment / stormwater</option>
        <option value="press">Media / press enquiry</option>
        <option value="other">Something else</option>
      </select>
    </div>

    <div>
      <label for="message" class="field-label field-required">Tell us a bit about it</label>
      <textarea
        id="message"
        name="message"
        rows="6"
        required
        class="field min-h-[140px] resize-y"
        placeholder="What you're growing or managing, roughly how big, what you're trying to solve, and any timing."
      ></textarea>
      <span class="field-help">Plain English is fine — we'll come back with the right questions.</span>
    </div>

    <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-4 mt-2">
      <p class="text-caption text-text-muted">
        We reply within two business days. By submitting you agree to be contacted about your enquiry.
      </p>
      <button type="submit" class="btn btn-primary !min-h-[52px] !text-body whitespace-nowrap">
        Send enquiry
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="22" y1="2" x2="11" y2="13" />
          <polygon points="22 2 15 22 11 13 2 9 22 2" />
        </svg>
      </button>
    </div>
  </form>
</div>
