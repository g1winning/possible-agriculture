---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/Hero.astro';
import Section from '@components/Section.astro';
import EnquiryForm from '@components/EnquiryForm.astro';
import { site } from '@lib/site';

const title = 'Contact Possible Agriculture';
const description = "Get in touch about biochar pricing, biological farming consults, forest management, carbon farming, or natural pools. We reply within two business days. Luca picks up.";

// Local-business schema for the contact page
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: site.name,
  description: site.description,
  url: site.url,
  telephone: site.founder.phoneTel,
  email: site.founder.email,
  areaServed: { '@type': 'Country', name: 'Australia' },
  address: {
    '@type': 'PostalAddress',
    addressRegion: site.location.region,
    addressCountry: 'AU',
  },
};

// Pre-fill subject from query string when JS-less (Astro reads at build time, so the form handles dynamically)
const url = Astro.url;
const subject = url.searchParams.get('subject') ?? 'Possible Agriculture enquiry';
const subjectLabel: Record<string, string> = {
  'biochar-quote': 'Biochar — pricing & delivery',
  'biochar-trial': 'Biochar — pilot trial on my property',
  'consult': 'Biological farming consult',
  'biological-farming-consult': 'Biological farming consult',
  'forest-management': 'Forest management',
  'carbon-farming': 'Carbon farming / ACCUs',
  'water-treatment': 'Water treatment',
  'turf-quote': 'Biochar for turf or golf',
  'livestock-quote': 'Biochar for livestock or dairy',
  'council-quote': 'Biochar for council / parkland',
  'farmer-quote': 'Biochar for farmer / feedlot',
  'dairy-trial': 'Dairy biochar trial scoping',
  'golf-trial': 'Golf course biochar trial scoping',
  'pilot-trial': 'Pilot trial scoping',
  'field-day': 'Regenerative farming group field day',
  'on-farm-production': 'On-farm biochar production day',
  'research-question': 'Research / library question',
  'compost-program': 'Compost program scoping',
  'council-procurement': 'Council procurement enquiry',
};
const prettySubject = subjectLabel[subject] ?? subject;
---

<BaseLayout
  title={title}
  description={description}
  schema={[localBusinessSchema]}
  showEnquiryRail={false}
>
  <Hero
    layout="minimal"
    eyebrow="Talk to us"
    heading="One founder, one phone number, one email."
    lead="The fastest way to get an answer is to call. If we're in the kiln paddock and miss it, leave a message — we'll come back to you the same day."
  />

  <Section container="default" spacing="default">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16">
      <!-- Contact details -->
      <div class="lg:col-span-5">
        <div class="bg-bark on-dark rounded-xl p-6 md:p-8 mb-6">
          <p class="eyebrow eyebrow-on-dark mb-3">Luca Brew · Founder</p>
          <h2 class="font-display font-bold text-h2 text-paper leading-tight">Talk to Luca.</h2>
          <ul class="mt-6 flex flex-col gap-4">
            <li>
              <a href={`tel:${site.founder.phoneTel}`} class="group flex items-center gap-3 text-body-lg text-paper hover:text-bush-gold no-underline">
                <span class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-bush-gold/20 transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z" />
                  </svg>
                </span>
                <span class="font-display font-semibold">{site.founder.phone}</span>
              </a>
            </li>
            <li>
              <a href={`mailto:${site.founder.email}`} class="group flex items-center gap-3 text-body text-paper hover:text-bush-gold no-underline break-all">
                <span class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-bush-gold/20 transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z" />
                    <polyline points="22,6 12,13 2,6" />
                  </svg>
                </span>
                <span>{site.founder.email}</span>
              </a>
            </li>
            <li>
              <a href={site.social.youtube} target="_blank" rel="noopener" class="group flex items-center gap-3 text-body text-paper hover:text-bush-gold no-underline">
                <span class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center shrink-0 group-hover:bg-bush-gold/20 transition-colors">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.33z" />
                    <polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02" fill="currentColor" />
                  </svg>
                </span>
                <span>@PossibleAgriculture on YouTube</span>
              </a>
            </li>
          </ul>
          <p class="mt-8 text-body-sm text-sky border-t border-white/10 pt-6">
            Based in {site.location.region}. Service area: {site.location.serviceArea}.
          </p>
        </div>
        <div class="bg-bg-tint border border-rule rounded-xl p-6 md:p-8">
          <h3 class="font-display font-bold text-h4-lg text-ink">When you'll hear back</h3>
          <ul class="mt-4 text-body text-text space-y-2">
            <li class="flex gap-3"><span class="text-bush-gold-600 font-bold">·</span>Phone — usually same day; leave a message if we miss you.</li>
            <li class="flex gap-3"><span class="text-bush-gold-600 font-bold">·</span>Form — within two business days.</li>
            <li class="flex gap-3"><span class="text-bush-gold-600 font-bold">·</span>Email — within two business days.</li>
          </ul>
        </div>
      </div>

      <!-- Form -->
      <div class="lg:col-span-7">
        <EnquiryForm
          subject={`Possible Agriculture enquiry — ${prettySubject}`}
          heading="Send an enquiry"
          intro="Plain English is fine — we'll come back with the right questions."
        />
      </div>
    </div>
  </Section>
</BaseLayout>
